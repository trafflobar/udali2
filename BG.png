* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Montserrat";
}

img {
  width: 100%;
  display: block;
}

a {
  text-decoration: none;
}

body {
  width: 100%;
  min-height: 100vh;
  background-image: url("../images/BG.png");
  background-position: center center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  background-size: cover;
  overflow-x: hidden;
  margin: 0;
}

.wrapper {
  max-width: 1720px;
  margin: 0 auto;
  width: 100%;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 20px;
}

.logo-wrapper {
  display: flex;
  justify-content: start;
}

.logo {
  max-width: 280px;
}

.flag {
  max-width: 150px;
}

.detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
}

h1 {
  font-size: 74px;
  font-weight: 500;
  color: #fff;
  animation: pulse 2s ease-in-out infinite;
  text-align: center;
  padding-bottom: 4%;
  font-style: italic;
}

.cards {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 70px;
  flex-wrap: nowrap;
}

.card img {
  max-width: 240px;
  transition: transform 0.3s ease;
  will-change: transform;
  cursor: pointer;
}

.card:hover img {
  transform: scale(1.05);
}

.footer__container {
  margin-top: auto;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  width: 100%;
  padding-bottom: 16px;
}

.footer__container .footer-text {
  grid-column: 1;
}

.footer-images {
  grid-column: 2;
}

.footer {
  width: 100%;
  max-width: 400px;
}

.cards-mobile {
  display: none;
}

.footer-mobile {
  display: none;
}

.footer-text {
  font-size: 20px;
  color: #fff;
  font-style: italic;
  font-weight: 700;
  background: black;
  background-clip: text;
  -webkit-text-stroke: 3px transparent;
  text-transform: uppercase;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

/* MEDIA */
@media (max-height: 700px) {
  .logo img {
    max-width: 250px;
  }
  h1 {
    font-size: clamp(1.5rem, 6vw, 3rem);
  }
  .cards {
    gap: 15px;
  }
  .card img {
    max-width: 130px;
  }
  .logo {
    max-width: 200px;
  }
  .flag {
    max-width: 110px;
  }
}

@media (max-height: 700px) {
  h1 {
    padding-bottom: 2%;
  }
}

@media (max-height: 500px) {
  .hero {
    padding: 10px;
  }
  .logo {
    margin-top: 10px;
  }
  .cards {
    gap: 10px;
  }
  .card img {
    max-width: 100px;
  }
  .footer__container img {
    max-width: 275px;
  }
}

@media (max-width: 1500px) {
  .cards {
    padding: 0 30px;
    gap: 25px;
  }

  .footer-text {
    font-size: 12px;
  }

  .footer {
    max-width: 320px;
  }
}

@media (max-width: 1000px) {
  .logo-wrapper {
    padding-top: 25px;
    justify-content: center;
  }

  .card img {
    max-width: 270px;
  }
  h1 {
    font-size: 45px;
  }
  .logo img {
    margin-bottom: 4%;
  }

  .detail {
    padding: 0 50px;
  }

  .cards {
    display: none;
  }
  .cards-mobile {
    display: block;
  }

  .cards-mobile div {
    margin-bottom: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
  }

  body {
    background-image: url(../images/bg-mobile.png);
  }

  .footer-mobile {
    display: block;
    max-width: 311px;
  }

  .footer__container {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 15px;
    margin-top: auto;
  }

  .footer-text {
    text-align: center;
    -webkit-text-stroke: 2px transparent;
  }

  .footer {
    display: none;
  }

  .wrapper {
    padding: 0 5px;
  }
}

@media (max-width: 600px) {
  h1 {
    font-size: 30px;
    text-align: center;
    padding-top: 3%;
    padding-bottom: 8%;
  }

  .logo {
    max-width: 200px;
    padding: 0 15px;
  }

  .flag {
    max-width: 80px;
  }

  .card-mobile {
    max-width: 200px;
  }

  .footer-text {
    font-size: 12px;
  }
}
